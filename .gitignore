# ──────────────────────────────────────────────
.playwright-mcp/

# ──────────────────────────────────────────────
# TypeScript build output
# ──────────────────────────────────────────────
dist/
*.tsbuildinfo

# ──────────────────────────────────────────────
# Editor — VS Code local/machine-specific config
# ──────────────────────────────────────────────
.vscode/mcp.json

# ──────────────────────────────────────────────
