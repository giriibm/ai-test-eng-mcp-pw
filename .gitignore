# Environment & secrets
# ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────
# Playwright — generated artefacts (root-level)
# ──────────────────────────────────────────────
/test-results/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# ──────────────────────────────────────────────
# Playwright-BDD — generated test files
# ──────────────────────────────────────────────
.features-gen/

# ──────────────────────────────────────────────
# Reports — entire folder excluded from version control
