{
  "name": "ai-test-eng-mcp-pw",
  "version": "1.0.0",
  "description": "E2E Test Suite - UI & API Testing with Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:bdd": "bddgen && playwright test --project=BDD-Smoke",
    "test:bdd:ui": "bddgen && playwright test .features-gen/tests/bdd/features/ui --project=BDD-Smoke",
    "test:bdd:api": "bddgen && playwright test .features-gen/tests/bdd/features/api --project=BDD-Smoke",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:ui-mode": "playwright test --ui",
    "test:list": "playwright test --list"
  },
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "api",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "playwright-bdd": "^8.5.1"
  }
}
